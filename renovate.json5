{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  kubernetes: {
    fileMatch: ["\\.yaml$"],
  },
  pinDigests: true,
  packageRules: [
    {
      // Digest-only updates = same version tag, new SHA digest = silent rebuild (CVE fix applied upstream).
      // These contain no version change — only security patches. Set automerge: true to merge automatically.
      matchUpdateTypes: ["digest"],
      automerge: false,
    },
  ],
}
